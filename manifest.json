{
  "manifest_version": 3,
  "name": "Notepad — notepad.pw Notes & Folders",
  "description": "Create, organize in folders, and open notepad.pw pages and rich-text notes (TinyMCE, Tiptap, plain text) from a sidebar on any page.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://notepad.pw/*",
    "https://notepad.cc/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Notes",
    "default_popup": "src/notes.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://notepad.pw/*",
        "http://notepad.pw/*",
        "https://notepad.cc/*",
        "http://notepad.cc/*"
      ],
      "js": [
        "src/notepad-sidebar.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/note-editor.html",
        "vendor/tinymce/*",
        "vendor/tinymce/*/*",
        "vendor/tinymce/*/*/*",
        "vendor/tinymce/*/*/*/*",
        "vendor/tiptap/*",
        "vendor/tiptap/*/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
